<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.pjw.app.announcement.notice.NoticeMapper">
  	<!-- list -->
  <select id="list" resultType="noticeDTO">
  		SELECT ANNOUNCEMENT_NUM,ANNOUNCEMENT_TITLE,ANNOUNCEMENT_WRITER FROM TB_NOTICE
  	</select>
  		<insert id="create" parameterType="noticeDTO">
  		INSERT INTO TB_NOTICE
  		VALUES
  		(
  			#{announcementNum}
  			#{announcementTitle}
  			#{announcementWriter}
  			#{announcementDate}
  			#{announcementHit}
  		)
  	</insert>
  	
  
  
 	<!-- create --> 
  </mapper>